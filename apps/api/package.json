      "domain-operations": "workspace:*",
      "utils": "workspace:*"
    },
    "devDependencies": {
      "@types/node": "^20.9.2",
      "@typescript-eslint/eslint-plugin": "^6.11.0",
      "@typescript-eslint/parser": "^6.11.0",
      "eslint": "^8.53.0",
      "eslint-config-prettier": "^9.0.0",
      "prettier": "^3.1.0",
      "prisma": "^5.5.2",
      "ts-node-dev": "^2.0.0",
      "typescript": "^5.2.2"
    }
  }