{
  "name": "oblien-domains",
  "version": "0.1.0",
  "private": true,
  "description": "Open Source Domain Register & Manager with the lowest cost domains directly from DNS providers",
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "check-types": "turbo run check-types",
    "build:docker": "turbo run build:docker",
    "prisma:generate": "turbo run prisma:generate",
    "prisma:migrate": "turbo run prisma:migrate",
    "prisma:studio": "turbo run prisma:studio"
  },
  "devDependencies": {
    "prettier": "^3.1.0",
    "turbo": "^2.4.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/oblien/oblien-domains.git"
  },
  "keywords": [
    "domain",
    "dns",
    "registration",
    "management",
    "nextjs",
    "react",
    "opensrs",
    "domain-registrar"
  ],
  "author": "Oblien Domains Team",
  "license": "AGPL-3.0-only",
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,json,md}": [
      "prettier --write"
    ]
  }
}